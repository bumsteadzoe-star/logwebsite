<!DOCTYPE html>
<html>
<head>
  <title>Log Social</title>
  <meta property="og:title" content="Check out this experience on Log" />
  <meta property="og:image" content="https://your-database.com/path-to-image.jpg" />
  <meta property="og:description" content="Click to view in the Log app." />
  <meta property="og:type" content="website" />

  <meta name="twitter:card" content="summary_large_image" />

  <script>
    // Replace POST_ID in your host template, or use server-side substitution for [id].
    const postId = new URLSearchParams(window.location.search).get('id') || 'POST_ID';
    window.location.href = 'log://post/' + encodeURIComponent(postId);
    setTimeout(() => {
      window.location.href = 'https://apps.apple.com/app/your-app-id';
    }, 2000);
  </script>
</head>
<body>
  <p>Opening Log...</p>
</body>
</html>